# Environment Variables Template
# Copy this file to .env and fill in your actual values

# Google Gemini API key (REQUIRED)
# Get from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_google_gemini_api_key_here

# Flask secret key (REQUIRED - Generate a secure one)
# Run: python generate_secret.py
SECRET_KEY=your_32_character_random_secret_key_here

# Twitter API (OPTIONAL - for real trending hashtags)
# Get from: https://developer.twitter.com/
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# Database (OPTIONAL - defaults to SQLite)
# For PostgreSQL: DATABASE_URL=postgresql://user:pass@host/db
DATABASE_URL=